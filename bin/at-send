#!/bin/sh
# =============================================================================
# at-send: Send an AT command to the Quectel modem and return the response.
# =============================================================================
#
# Part of: asus-lte-telemetry
# https://github.com/pajus1337/asus-lte-telemetry
#
# Tested on:
#   ASUS 4G-AC86U + Quectel EM12-G + firmware EM12GPAR01A21M4G
#
# Usage:
#   at-send "AT+COMMAND" [timeout_seconds]
#
# Environment variables (override defaults):
#   AT_PORT          - serial port (overrides auto-detect; e.g. /dev/ttyUSB3)
#   AT_TIMEOUT       - default timeout in seconds (default: 1.5)
#   AT_INIT_DELAY    - delay before sending command (default: 0.2)
#
# Exit codes:
#   0  - command sent, response returned on stdout (may still contain ERROR)
#   1  - usage error or port not accessible
#   2  - required dependency missing
#
# Dependencies (Entware):
#   coreutils-sleep  (for fractional-second sleep)
#   coreutils-mktemp
#
# Locking:
#   Uses flock -x /tmp/at_cmd_lock — the same lock as ASUS firmware
#   (modem_at.sh). This prevents simultaneous tty access that corrupts AT
#   responses and can trigger firmware LTE reconnect cycles.
# =============================================================================

set -u

readonly SLEEP_BIN="/opt/bin/sleep"
readonly MKTEMP_BIN="/opt/bin/mktemp"
readonly DEFAULT_TIMEOUT="${AT_TIMEOUT:-1.5}"
readonly INIT_DELAY="${AT_INIT_DELAY:-0.2}"
readonly AT_LOCK="/tmp/at_cmd_lock"

# Resolve AT port: explicit env override > firmware nvram cache > hardcoded default.
# ASUS firmware stores the active AT port in nvram usb_modem_act_int (e.g. "ttyUSB3").
# Reading it avoids hardcoding a port that firmware may reassign.
if [ -n "${AT_PORT:-}" ]; then
    PORT="$AT_PORT"
else
    _nvram_node=""
    if command -v nvram >/dev/null 2>&1; then
        _nvram_node=$(nvram get usb_modem_act_int 2>/dev/null)
    fi
    if [ -n "$_nvram_node" ]; then
        PORT="/dev/$_nvram_node"
    else
        PORT="/dev/ttyUSB3"
    fi
fi

# -- argument parsing --------------------------------------------------------
CMD="${1:-}"
TIMEOUT="${2:-$DEFAULT_TIMEOUT}"

if [ -z "$CMD" ]; then
    cat >&2 <<EOF
Usage: at-send "AT+COMMAND" [timeout_seconds]

Examples:
  at-send "ATI"
  at-send 'AT+QENG="servingcell"'
  at-send "AT+QTEMP" 2

Environment:
  AT_PORT=/dev/ttyUSB0 at-send "ATI"
EOF
    exit 1
fi

# -- dependency checks -------------------------------------------------------
if [ ! -x "$SLEEP_BIN" ]; then
    echo "ERROR: $SLEEP_BIN not found. Install: opkg install coreutils-sleep" >&2
    exit 2
fi

if [ ! -x "$MKTEMP_BIN" ]; then
    echo "ERROR: $MKTEMP_BIN not found. Install: opkg install coreutils-mktemp" >&2
    exit 2
fi

if [ ! -c "$PORT" ]; then
    echo "ERROR: Serial port $PORT not found or not a character device" >&2
    exit 1
fi

# -- main --------------------------------------------------------------------
TMP=$("$MKTEMP_BIN" /tmp/at-send.XXXXXX)
trap 'rm -f "$TMP"' EXIT INT TERM

# Acquire the same exclusive lock used by ASUS firmware (modem_at.sh line 25).
# Prevents simultaneous port access that corrupts responses and triggers LTE
# reconnect cycles in the router firmware.
exec 9>"$AT_LOCK"
flock -x 9

# Flush stale data from the serial port's kernel receive buffer.
# Other router processes may write AT commands to this port periodically,
# leaving buffered garbage (including ERROR lines) that would corrupt our read.
cat "$PORT" > /dev/null 2>/dev/null &
_DRAIN_PID=$!
"$SLEEP_BIN" 0.2
kill "$_DRAIN_PID" 2>/dev/null
wait "$_DRAIN_PID" 2>/dev/null

# Start background reader (after drain, buffer is mostly clean)
cat "$PORT" > "$TMP" 2>/dev/null &
CAT_PID=$!

# Allow reader to attach before transmitting
"$SLEEP_BIN" "$INIT_DELAY"

# Transmit command with CR terminator
printf '%s\r' "$CMD" > "$PORT"

# Wait for response to accumulate
"$SLEEP_BIN" "$TIMEOUT"

# Stop reader
kill "$CAT_PID" 2>/dev/null
wait "$CAT_PID" 2>/dev/null

# Release lock (closing fd releases flock automatically)
exec 9>&-

# Emit response starting from our command echo.
# The modem echoes back what we write (ATE1 default). Any data captured
# before the echo is buffered garbage from other port users — discard it.
# Falls back to full output if no echo is found (ATE0 / echo disabled).
_after_echo=$(awk -v cmd="$CMD" '
BEGIN { past=0 }
past { print; next }
index($0, cmd) > 0 { past=1 }
' "$TMP")

if [ -n "$_after_echo" ]; then
    printf '%s\n' "$_after_echo"
else
    cat "$TMP"
fi

exit 0
